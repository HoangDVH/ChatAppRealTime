# Server
PORT=5001
CLIENT_URL=http://localhost:5174
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_CONNECTIONSTRING=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/dev?ssl=true&replicaSet=REPLICA_SET&authSource=admin&retryWrites=true&w=majority

# JWT secret (generate a long random string)
ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Cloudinary (Dashboard → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Production on Render:
# NODE_ENV=production
# PORT is set automatically by Render
# CLIENT_URL=https://YOUR-APP.vercel.app  (no trailing slash)
# Atlas Network Access must allow 0.0.0.0/0
